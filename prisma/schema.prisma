generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Auth
// ─────────────────────────────────────────

model User {
  id             String        @id @default(cuid())
  name           String?
  email          String        @unique
  passwordHash   String
  role           Role          @default(STUDENT)
  createdAt      DateTime      @default(now())

  createdCourses     Course[]            @relation("CreatedCourses")
  attempts           QuizAttempt[]
  progress           Progress[]
  orders             Order[]             @relation("StudentOrders")
  enrollments        Enrollment[]
  reviewedOrders     Order[]             @relation("OrderReviewer")
  courseReviews      CourseReview[]
  discussionThreads  DiscussionThread[]
  discussionReplies  DiscussionReply[]
  chatbotMessages    CourseChatMessage[]
}

enum Role {
  STUDENT
  ADMIN
}

// ─────────────────────────────────────────
// Course & Lesson
// ─────────────────────────────────────────

model Course {
  id           String       @id @default(cuid())
  title        String
  description  String       @db.Text
  thumbnailUrl String?
  price        Float        @default(0)
  status       CourseStatus @default(DRAFT)
  viewCount    Int          @default(0)
  createdBy    String
  createdAt    DateTime     @default(now())

  creator           User                 @relation("CreatedCourses", fields: [createdBy], references: [id])
  lessons           Lesson[]
  enrollments       Enrollment[]
  orderItems        OrderItem[]
  reviews           CourseReview[]
  discussionThreads DiscussionThread[]
  chatbotMessages   CourseChatMessage[]
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

model Lesson {
  id          String      @id @default(cuid())
  courseId    String
  title       String
  contentType ContentType
  content     String      @db.Text
  summary     String?     @db.Text
  durationText String?
  order       Int
  isPreview   Boolean     @default(false)
  viewCount   Int         @default(0)

  course            Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quizzes           Quiz[]
  progress          Progress[]
  discussionThreads DiscussionThread[]
}

enum ContentType {
  VIDEO
  TEXT
}

// —————————————————————————————————————————
// Commerce
// —————————————————————————————————————————

model Order {
  id             String      @id @default(cuid())
  userId         String
  totalAmount    Float
  status         OrderStatus @default(PENDING)
  slipUrl        String?
  slipUploadedAt DateTime?
  reviewedAt     DateTime?
  reviewedById   String?
  createdAt      DateTime    @default(now())

  user        User         @relation("StudentOrders", fields: [userId], references: [id])
  reviewedBy  User?        @relation("OrderReviewer", fields: [reviewedById], references: [id])
  items       OrderItem[]
  enrollments Enrollment[]
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  courseId String
  price    Float

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id])

  @@unique([orderId, courseId])
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  orderId    String?
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])
  order  Order? @relation(fields: [orderId], references: [id])

  @@unique([userId, courseId])
}

model CourseReview {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int
  review    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model DiscussionThread {
  id        String   @id @default(cuid())
  courseId  String
  lessonId  String?
  userId    String
  title     String
  content   String   @db.Text
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson  Lesson?           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]
}

model DiscussionReply {
  id        String   @id @default(cuid())
  threadId  String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseChatMessage {
  id        String   @id @default(cuid())
  courseId  String
  userId    String?
  prompt    String   @db.Text
  response  String   @db.Text
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// Quiz
// ─────────────────────────────────────────

model Quiz {
  id            String @id @default(cuid())
  lessonId      String
  question      String
  choices       String[]
  correctAnswer String

  lesson   Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts QuizAttempt[]
}

model QuizAttempt {
  id             String  @id @default(cuid())
  userId         String
  quizId         String
  selectedAnswer String
  isCorrect      Boolean

  user User @relation(fields: [userId], references: [id])
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Progress
// ─────────────────────────────────────────

model Progress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}
